#include <ArduinoJson.h>

void setup() {
  Serial.begin(115200);
  Serial.println("Analizador iniciado. Ingrese JSON:");
}

void loop() {
  if (Serial.available()) {
    String entrada = Serial.readStringUntil('\n');
    entrada.trim();

    if (entrada.length() == 0) return;

    StaticJsonDocument<512> doc;
    DeserializationError error = deserializeJson(doc, entrada);

    if (error) {
      Serial.println("No se ha ingrezado un numero valido, intente de nuevo");
      return;
    }

    const char* kID = doc.containsKey("ID") ? "ID" : (doc.containsKey("id") ? "id" : NULL);
    const char* kTemp = doc.containsKey("Temperatura") ? "Temperatura" : (doc.containsKey("temperatura") ? "temperatura" : NULL);
    const char* kHum = doc.containsKey("Humedad") ? "Humedad" : (doc.containsKey("humedad") ? "humedad" : NULL);
    const char* kDist = doc.containsKey("Distancia") ? "Distancia" : (doc.containsKey("distancia") ? "distancia" : NULL);

    if (!kID || !kTemp || !kHum || !kDist) {
      Serial.println("Error: faltan datos");
      return;
    }

    if (!doc[kID].is<String>()) {
      return;
    }

    if (!doc[kTemp].is<float>() || !doc[kHum].is<float>() || !doc[kDist].is<float>()) {
      return;
    }

    String id = doc[kID].as<String>();
    float temp = doc[kTemp].as<float>();
    float hum = doc[kHum].as<float>();
    float dist = doc[kDist].as<float>();

    Serial.print("se ha ingresado el numero ");
    Serial.println(temp);

    Serial.println("Estado actual:");
    Serial.print("ID: ");
    Serial.println(id);
    Serial.print("Temperatura: ");
    Serial.println(temp);
    Serial.print("Humedad: ");
    Serial.println(hum);
    Serial.print("Distancia: ");
    Serial.println(dist);
    
    Serial.println("Ingrese un nuevo dato JSON");
  }
}
